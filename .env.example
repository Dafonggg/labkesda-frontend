# ============================================================
# FRONTEND (.env) - Konfigurasi Environment Variables
# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya.
# cp .env.example .env
# ============================================================
# CATATAN: Semua variabel HARUS diawali dengan prefix VITE_
# agar dapat diakses di kode frontend via import.meta.env.VITE_*
# ============================================================
# PENTING: Env frontend untuk production sudah dikonfigurasi
# langsung di dashboard Vercel (Settings > Environment Variables).
# File .env ini hanya digunakan untuk development lokal.
# ============================================================

# ----------------------------------------------------------
# API Configuration
# ----------------------------------------------------------

# VITE_API_URL
# Deskripsi : URL dasar (base URL) API backend yang digunakan oleh
#             aplikasi frontend untuk melakukan request data.
# Format    : https://<domain>/api/v1 atau http://localhost:8000/api/v1
# Contoh    :
#   - Production : https://labkesda-backend-production.up.railway.app/api/v1
#   - Local      : http://localhost:8000/api/v1
# Penggunaan: import.meta.env.VITE_API_URL
# Wajib     : Ya
VITE_API_URL=http://localhost:8000/api/v1

# ----------------------------------------------------------
# Frontend URL
# ----------------------------------------------------------

# VITE_FRONTEND_URL
# Deskripsi : URL dasar aplikasi frontend itu sendiri.
#             Digunakan untuk generate link (misalnya link reset password
#             yang dikirim via email) agar mengarah ke halaman frontend.
# Format    : https://<domain> atau http://localhost:5173
# Contoh    :
#   - Production : https://labkesda-frontend.vercel.app
#   - Local      : http://localhost:5173
# Penggunaan: import.meta.env.VITE_FRONTEND_URL
# Wajib     : Ya
VITE_FRONTEND_URL=http://localhost:5173
